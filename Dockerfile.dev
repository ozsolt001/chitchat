# Development Dockerfile for backend
FROM mcr.microsoft.com/dotnet/sdk:8.0

WORKDIR /app

# Install dotnet watch tool globally
RUN dotnet tool install -g dotnet-watch

# Add to PATH so dotnet-watch is accessible
ENV PATH="${PATH}:/root/.dotnet/tools"

# Expose port
EXPOSE 8080

# Run with dotnet watch for hot reload
ENTRYPOINT ["dotnet", "watch", "run", "--project", "src/ChatApp.Backend.csproj"]
